# Sawla Tours — environment variables
# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.
# The site builds and runs WITHOUT any of these set — enquiries are logged to the
# server console instead of emailed, and analytics simply no-ops.

# ── Enquiry email delivery (Resend — https://resend.com) ──────────────────────
# Until RESEND_API_KEY is set, POST /api/enquire validates and logs submissions
# but sends no email, so the form works in local development.
RESEND_API_KEY=
# Inbox that receives enquiries (defaults to explore@sawlatours.com if unset)
ENQUIRY_TO=explore@sawlatours.com
# Verified sender on your Resend domain (defaults to enquiries@sawlatours.com)
ENQUIRY_FROM=Sawla Tours <enquiries@sawlatours.com>

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Omit to disable analytics.
NEXT_PUBLIC_GA_ID=
